<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.user.face-profile-daemon</string>

    <!-- ProgramArguments.0 is overwritten by 'make install' via plutil -replace
         with the absolute path to the installed binary. -->
    <key>ProgramArguments</key>
    <array>
        <string>/REPLACED_BY_MAKE_INSTALL/face-profile-daemon</string>
    </array>

    <!-- Restart automatically on crash; wait at least 10 s before relaunch -->
    <key>KeepAlive</key>
    <true/>
    <key>ThrottleInterval</key>
    <integer>10</integer>

    <!-- Start immediately when the LaunchAgent is loaded -->
    <key>RunAtLoad</key>
    <true/>

    <!-- Daemon uses os_log (Logger) for all logging; redirect stdout/stderr to
         /dev/null to avoid unbounded log file growth on disk. -->
    <key>StandardOutPath</key>
    <string>/dev/null</string>
    <key>StandardErrorPath</key>
    <string>/dev/null</string>
</dict>
</plist>
